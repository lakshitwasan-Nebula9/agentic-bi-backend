APP_NAME=Agentic BI
DEBUG=false
API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql://user:password@localhost:5432/agentic_bi
REDIS_URL=redis://localhost:6379/0

# SQLAlchemy connection pool sizing. Defaults stay low — Supabase's session-mode
# pooler shares a 15-connection budget across ALL clients. Raise only for a
# dedicated/production pooler with more headroom.
DB_POOL_SIZE=3
DB_MAX_OVERFLOW=2
DB_POOL_TIMEOUT=10

JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

GOOGLE_OAUTH_CLIENT_ID=645931951060-40c3r5b86fnvmgb1usbfjb4eulugq34i.apps.googleusercontent.com
GOOGLE_OAUTH_ALLOWED_DOMAIN=

# Fernet key used to encrypt connector credentials at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CONNECTOR_ENCRYPTION_KEY=change-me-32-byte-fernet-key-base64==

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_LLM_MODEL=gemini-1.5-flash

EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL="https://us.cloud.langfuse.com"

# Rate limiting (Redis fixed-window; "N/second|minute|hour")
RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_LLM=20/minute
RATE_LIMIT_DEFAULT=300/minute
